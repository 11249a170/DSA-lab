        scanf("%d", &items[i]);
    }

    printf("Enter bin capacity: ");
    scanf("%d", &capacity);   // FIXED: %d instead of %f

    firstFit(items, n, capacity);

    return 0;
}


Implementation of Bin Packing Algorithms
